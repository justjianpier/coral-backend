{
  "openapi": "3.0.0",
  "info": {
    "title": "Coral Store API",
    "description": "Documentación de la API de Coral Store para el proyecto de Tecsup",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:5000/api/v1",
      "description": "Servidor Local de Desarrollo"
    }
  ],
  "paths": {
    "/products": {
      "get": {
        "summary": "Obtener todos los productos activos",
        "responses": {
          "200": {
            "description": "Lista de productos obtenida con éxito"
          }
        }
      },
      "post": {
        "summary": "Crear un nuevo producto manualmente",
        "description": "Crea un producto usando codificación multipart/form-data para adjuntar la imagen física.",
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "description": { "type": "string" },
                  "brand": { "type": "string" },
                  "size": { "type": "string" },
                  "price": { "type": "number" },
                  "stock": { "type": "integer" },
                  "category_id": { "type": "integer" },
                  "image": { "type": "string", "format": "binary" }
                },
                "required": ["name", "price", "category_id", "image"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Producto creado con éxito" },
          "400": { "description": "Error de validación o fallo en la carga de imagen" }
        }
      }
    },
    "/products/{product_id}": {
      "get": {
        "summary": "Obtener un producto por su ID",
        "parameters": [
          {
            "name": "product_id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": { "description": "Detalle del producto" },
          "404": { "description": "Producto no encontrado" }
        }
      },
      "put": {
        "summary": "Editar o actualizar un producto existente",
        "parameters": [
          {
            "name": "product_id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "description": { "type": "string" },
                  "brand": { "type": "string" },
                  "size": { "type": "string" },
                  "price": { "type": "number" },
                  "stock": { "type": "integer" },
                  "category_id": { "type": "integer" },
                  "image": { "type": "string", "format": "binary" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Producto actualizado con éxito" },
          "404": { "description": "Producto no encontrado" }
        }
      },
      "delete": {
        "summary": "Desactivar un producto (Eliminado lógico)",
        "parameters": [
          {
            "name": "product_id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": { "description": "Producto desactivado con éxito" },
          "404": { "description": "Producto no encontrado" }
        }
      }
    },
    "/products/sync": {
      "post": {
        "summary": "Sincronizar semilla de productos desde FakeStoreAPI",
        "responses": {
          "200": { "description": "Sincronización exitosa" }
        }
      }
    }
  }
}